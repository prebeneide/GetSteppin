{
  "expo": {
    "name": "steppin",
    "slug": "steppin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1ED760"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourname.steppin",
      "buildNumber": "1",
      "infoPlist": {
        "NSMotionUsageDescription": "Denne appen trenger tilgang til bevegelsesdata for å telle skritt.",
        "NSPhotoLibraryUsageDescription": "Appen trenger tilgang til bilder for å laste opp profilbilde.",
        "NSCameraUsageDescription": "Appen trenger tilgang til kamera for å ta profilbilde."
      }
    },
    "android": {
      "package": "com.yourname.steppin",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1ED760"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACTIVITY_RECOGNITION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
